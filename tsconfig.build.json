{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "types": ["react", "react-dom"]
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/*.test.*", "src/**/__tests__/**", "src/setupTests.ts"]
}
